          "onboarding.page1.title" : {
            "extractionState" : "manual",
            "localizations" : {
              "en" : { "stringUnit" : { "state" : "translated", "value" : "Africa trading Platform" } },
              "fr" : { "stringUnit" : { "state" : "translated", "value" : "Plateforme de commerce africaine" } },
              "rw" : { "stringUnit" : { "state" : "translated", "value" : "Urubuga rw’ubucuruzi rwa Afurika" } },
              "sw" : { "stringUnit" : { "state" : "translated", "value" : "Jukwaa la biashara la Afrika" } }
            }
          },

          "onboarding.page1.description" : {
            "extractionState" : "manual",
            "localizations" : {
              "en" : { "stringUnit" : { "state" : "translated", "value" : "Connecting and empowering entrepreneurs across the region by providing access to a vibrant marketplace and essential business tools." } },
              "fr" : { "stringUnit" : { "state" : "translated", "value" : "Connecter et autonomiser les entrepreneurs de la région grâce à un marché dynamique et des outils essentiels." } },
              "rw" : { "stringUnit" : { "state" : "translated", "value" : "Guhuza no kongerera ubushobozi ba rwiyemezamirimo mu karere binyuze ku isoko rikora neza n’ibikoresho by’ingenzi." } },
              "sw" : { "stringUnit" : { "state" : "translated", "value" : "Kuunganisha na kuwawezesha wajasiriamali kupitia soko lenye shughuli na zana muhimu za biashara." } }
            }
          },

          "onboarding.page2.title" : {
            "extractionState" : "manual",
            "localizations" : {
              "en" : { "stringUnit" : { "state" : "translated", "value" : "Buy & Sell" } },
              "fr" : { "stringUnit" : { "state" : "translated", "value" : "Acheter et vendre" } },
              "rw" : { "stringUnit" : { "state" : "translated", "value" : "Gura no kugurisha" } },
              "sw" : { "stringUnit" : { "state" : "translated", "value" : "Nunua na uza" } }
            }
          },

          "onboarding.page2.description" : {
            "extractionState" : "manual",
            "localizations" : {
              "en" : { "stringUnit" : { "state" : "translated", "value" : "Access a vibrant marketplace where you can buy quality products from trusted sellers or showcase your own goods and services to thousands of potential customers." } },
              "fr" : { "stringUnit" : { "state" : "translated", "value" : "Accédez à un marché dynamique où vous pouvez acheter des produits de qualité ou vendre vos propres biens." } },
              "rw" : { "stringUnit" : { "state" : "translated", "value" : "Kwinjira ku isoko rikomeye aho ushobora kugura cyangwa kugurisha ibicuruzwa byawe." } },
              "sw" : { "stringUnit" : { "state" : "translated", "value" : "Fikia soko lenye shughuli ambapo unaweza kununua au kuuza bidhaa zako." } }
            }
          },

          "onboarding.page3.title" : {
            "extractionState" : "manual",
            "localizations" : {
              "en" : { "stringUnit" : { "state" : "translated", "value" : "Expand Your Business" } },
              "fr" : { "stringUnit" : { "state" : "translated", "value" : "Développez votre entreprise" } },
              "rw" : { "stringUnit" : { "state" : "translated", "value" : "Kwagura ubucuruzi bwawe" } },
              "sw" : { "stringUnit" : { "state" : "translated", "value" : "Panua biashara yako" } }
            }
          },

          "onboarding.page3.description" : {
            "extractionState" : "manual",
            "localizations" : {
              "en" : { "stringUnit" : { "state" : "translated", "value" : "Get real-time market prices, use a currency converter, and a simple bookkeeping tool." } },
