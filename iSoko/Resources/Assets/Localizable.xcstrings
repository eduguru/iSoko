        "common.signup.option_individual_description": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Perfect for sole proprietor, freelancers, and individual business owners managing their own operations"
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Idéal pour les auto-entrepreneurs, les freelances et les propriétaires d'entreprises individuelles gérant leurs propres opérations"
                    }
                },
                "rw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Ikwiye inzobere, abakora ubwabo, n'abanyabikorwa bafata ibyemezo bagenzi"
                    }
                },
                "sw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Kamili kwa wafanyabiashara wa peke yao, wakandarasi huru, na wamiliki wa biashara binafsi"
                    }
                }
            }
        },
