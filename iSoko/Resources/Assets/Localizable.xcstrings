{
    "sourceLanguage": "en",
    "strings": {
        "common.reset_password.header_title": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Forgot password?"
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Mot de passe oublié ?"
                    }
                },
                "rw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Wibagiwe ijambo banga?"
                    }
                },
                "sw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Umesahau nywila?"
                    }
                }
            }
        },
        "common.reset_password.header_description": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Don’t worry! It happens. Please enter the email associated with your account."
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Ne vous inquiétez pas ! Cela arrive. Veuillez saisir l'e-mail associé à votre compte."
                    }
                },
                "rw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Ntugire impungenge! Biba. Injiza imeli ishamikiye kuri konti yawe."
                    }
                },
                "sw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Usijali! Hutokea. Tafadhali weka barua pepe inayohusiana na akaunti yako."
                    }
                }
            }
        },
        "common.reset_password.email_placeholder": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Enter email"
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Saisir l'e-mail"
                    }
                },
                "rw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Injiza imeli"
                    }
                },
                "sw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Weka barua pepe"
                    }
                }
            }
        },
        "common.reset_password.email_required_error": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Email is required"
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "L'e-mail est obligatoire"
                    }
                },
                "rw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Imeli irasabwa"
                    }
                },
                "sw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Barua pepe inahitajika"
                    }
                }
            }
        },
        "common.reset_password.email_length_error": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Must be 5–50 characters"
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Doit contenir entre 5 et 50 caractères"
                    }
                },
                "rw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Igomba kuba imyanya 5–50"
                    }
                },
                "sw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Lazima iwe herufi 5–50"
                    }
                }
            }
        },
        "common.reset_password.email_label": {
            "extractionState": "manual",
            "localizations": {
                "en": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Email address"
                    }
                },
                "fr": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Adresse e-mail"
                    }
                },
                "rw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Aderesi ya imeli"
                    }
                },
                "sw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Anwani ya barua pepe"
                    }
                }
