                "rw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Ikwiye amasosiyete, ubufatanye, amakoperative, n'imiryango ifite abafatanyabikorwa benshi"
                    }
                },
                "sw": {
                    "stringUnit": {
                        "state": "translated",
                        "value": "Inafaa kwa makampuni, ushirikiano, vyama vya ushirika, na mashirika yenye wadau wengi"
